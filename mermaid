#!/usr/bin/env python3
"""mermaid — AI 出图,直接开网页工作台 / one command from text to a diagram workbench.

用法:
  mermaid                     ▶ 粘贴模式:回车后粘贴任意文本,Ctrl-D 出图(推荐,免转义)
  mermaid <文件路径>          拖一个文件(.mmd/.txt/.md 均可)
  mermaid <mermaid 代码>      自动视觉美化后打开(原稿保留 *-raw.mmd)
  mermaid <自然语言描述>       AI 生成图后打开
  pbpaste | mermaid           复制后从剪贴板直接出图
  mermaid -h                  本说明

注意: 文本含括号/管道/引号等特殊字符时 shell 会先拆参数——用粘贴模式或管道,
      别直接裸贴。(zsh 用户可配 alias mermaid='noglob mermaid' 免疫普通括号)
"""
import json, os, re, socket, subprocess, sys, time, urllib.request

# 工作台目录 = 本脚本所在目录(装到 PATH 的是 symlink,realpath 解回 repo);可用 env 覆盖
WORKBENCH = os.environ.get('MERMAIDFIX_HOME') or os.path.dirname(os.path.realpath(__file__))
PORT = int(os.environ.get('MERMAIDFIX_PORT', 8642))

FENCE = re.compile(r'```mermaid\s*\n(.*?)```', re.DOTALL)
DIAGRAM_HEAD = re.compile(
    r'^\s*(---\n|graph\s|flowchart\s|sequenceDiagram|classDiagram|stateDiagram'
    r'|erDiagram|journey|gantt|pie\s|pie\n|mindmap|timeline|quadrantChart|gitGraph'
    r'|C4Context|sankey|xychart|block-beta|packet|kanban|architecture|radar|requirementDiagram)',
    re.IGNORECASE)

RECIPE = '''你是 mermaid 视觉专家。只输出一段 mermaid 代码本身:不要解释、不要 markdown 围栏、不要任何代码以外的文字。

硬性视觉配方(必须全部遵守):
1. 顶部加 YAML frontmatter config。flowchart/graph 类用:
---
config:
  layout: elk
  look: classic
  theme: base
  elk:
    mergeEdges: false
    nodePlacementStrategy: NETWORK_SIMPLEX
  themeVariables:
    fontFamily: "PingFang SC, Hiragino Sans GB, Microsoft YaHei, sans-serif"
    fontSize: "13px"
    lineColor: "#94a3b8"
    edgeLabelBackground: "#f8f8fc"
  flowchart:
    nodeSpacing: 45
    rankSpacing: 55
    padding: 12
    wrappingWidth: 360
---
其他图型(sequence/gantt/pie 等)保留 look/theme/themeVariables,删掉 layout/elk/flowchart 段。
2. 白底浅色审美:节点一律浅色填充 + 饱和彩色描边 + 同色系深色文字(classDef 定义),禁止深底白字。参考色板:
   蓝 fill:#dbeafe,stroke:#2563eb,color:#1e3a8a   红 fill:#fee2e2,stroke:#dc2626,color:#7f1d1d(阻塞/风险,stroke-width:3px)
   橙 fill:#ffedd5,stroke:#ea580c,color:#7c2d12   绿 fill:#dcfce7,stroke:#16a34a,color:#14532d
   紫 fill:#ede9fe,stroke:#8b5cf6,color:#4c1d95   灰 fill:#f1f5f9,stroke:#94a3b8,color:#64748b(完成/弱化)
3. 语义分层:关键路径/阻塞链用 linkStyle 标红加粗(stroke:#dc2626,stroke-width:2px);参照/弱关系用虚线 -.->;subgraph 用 style 上极淡底色(#eff6ff/#fff7ed/#f0fdf4/#faf5ff 系)+ 同系浅描边。
   ⚠ linkStyle 索引从 0 计数、必须严格小于边总数——写之前先数清楚有几条边,宁可少标不要越界(越界 = 渲染直接崩)。class/style 只能引用已定义的节点 ID。
4. 节点文字用 <br/> 控制在两行以内;重复语义的边标签只保留一条;subgraph 标题带一个贴切 emoji;字符串 label 一律用双引号包裹。
5. 输出必须语法合法,能被 mermaid v11 直接渲染。'''

def usage():
    print(__doc__.strip())
    print(f'\n工作台: {WORKBENCH}  ·  http://localhost:{PORT}/preview.html')

def load_config():
    p = os.path.join(WORKBENCH, 'config.json')
    if not os.path.exists(p):
        sys.exit(f'mermaid: 缺少 {p}\n'
                 f'  cd {WORKBENCH} && cp config.example.json config.json,填入你的 API key')
    with open(p) as f:
        return json.load(f)

def read_input(argv):
    if len(argv) == 1 and os.path.isfile(argv[0]):
        with open(argv[0], encoding='utf-8', errors='replace') as f:
            return f.read()
    return ' '.join(argv)

def pick_code(text):
    """返回 (mermaid代码 or None)。None = 按自然语言处理。"""
    m = FENCE.search(text)
    if m:
        return m.group(1).strip()
    if DIAGRAM_HEAD.match(text):
        return text.strip()
    return None

def sanitize(code):
    """清理 AI 偶发的畸形 linkStyle:数字长龙整行删(纯装饰,删了不影响语义)、尾逗号去掉。"""
    out = []
    for l in code.split('\n'):
        if l.lstrip().startswith('linkStyle'):
            if len(l) > 500:  # 失控产物:0,1,2,…,2496 这类数列,必崩渲染
                continue
            l = re.sub(r',\s*$', '', l)
            l = re.sub(r'(\d)\s*,\s+(?=stroke|fill|color)', r'\1 ', l)
        out.append(l)
    return '\n'.join(out)

def call_ai(cfg, user_content):
    req = urllib.request.Request(
        cfg['endpoint'].rstrip('/') + '/v1/chat/completions',
        data=json.dumps({
            'model': cfg['model'],
            'messages': [{'role': 'system', 'content': RECIPE},
                         {'role': 'user', 'content': user_content}],
            'max_tokens': 8000,
            'enable_thinking': False,  # 关 reasoning 提速;非 deepseek 网关会忽略此参数
        }).encode(),
        headers={'Authorization': 'Bearer ' + cfg['key'],
                 'Content-Type': 'application/json'})
    with urllib.request.urlopen(req, timeout=120) as r:
        data = json.load(r)
    out = data['choices'][0]['message']['content'].strip()
    m = FENCE.search(out) or re.search(r'```\s*\n(.*?)```', out, re.DOTALL)
    return m.group(1).strip() if m else out

def ensure_server():
    try:
        socket.create_connection(('127.0.0.1', PORT), timeout=0.5).close()
        return
    except OSError:
        pass
    subprocess.Popen([sys.executable, os.path.join(WORKBENCH, 'serve.py'), str(PORT)],
                     cwd=WORKBENCH, stdout=subprocess.DEVNULL,
                     stderr=subprocess.DEVNULL, start_new_session=True)
    for _ in range(20):
        try:
            socket.create_connection(('127.0.0.1', PORT), timeout=0.5).close()
            return
        except OSError:
            time.sleep(0.2)
    sys.exit('mermaid: 工作台服务(serve.py)启动失败')

def open_browser(url, cfg):
    if os.environ.get('MERMAID_NO_OPEN'):
        return
    browser = cfg.get('browser') or ''
    if sys.platform == 'darwin':
        cmd = ['open', '-a', browser, url] if browser else ['open', url]
    else:
        cmd = [browser, url] if browser else ['xdg-open', url]
    subprocess.run(cmd, check=False)

def main():
    argv = sys.argv[1:]
    if argv and argv[0] in ('-h', '--help'):
        usage()
        return
    if argv:
        text = read_input(argv)
    elif not sys.stdin.isatty():
        text = sys.stdin.read()  # 管道: pbpaste | mermaid / cat x.md | mermaid
    else:
        usage()
        print('\n▶ 粘贴模式:直接粘贴内容,按 Ctrl-D 出图(Ctrl-C 退出)…', file=sys.stderr)
        text = sys.stdin.read()
    if not text.strip():
        return

    cfg = load_config()
    stamp = time.strftime('%m%d-%H%M%S')
    code = pick_code(text)
    name = f'{stamp}.mmd'
    path = os.path.join(WORKBENCH, name)
    url = f'http://localhost:{PORT}/preview.html?f={name}'

    def write(content):
        with open(path, 'w', encoding='utf-8') as f:
            f.write(content.rstrip() + '\n')

    # 先落占位图、开浏览器,AI 完成后覆写 —— 页面 2s 轮询会自动换成成品
    verb = '生成' if code is None else '美化'
    write('flowchart LR\n'
          f'    W["⏳ AI {verb}中… 页面会自动刷新,不用动"]\n'
          '    style W fill:#fef9c3,stroke:#eab308,color:#713f12\n')
    ensure_server()
    print(f'mermaid: {path}\nmermaid: {url}', flush=True)
    open_browser(url, cfg)

    try:
        if code is None:
            print('mermaid: AI 生成中(浏览器已打开,图好了自动出现)…', file=sys.stderr)
            final = call_ai(cfg, '根据以下需求画一张图:\n\n' + text)
        else:
            with open(os.path.join(WORKBENCH, f'{stamp}-raw.mmd'), 'w', encoding='utf-8') as f:
                f.write(code + '\n')
            print('mermaid: AI 视觉美化中(原稿已存 %s-raw.mmd;浏览器已打开)…' % stamp, file=sys.stderr)
            final = call_ai(cfg, '重写下面这段 mermaid:保持节点、连线、文字的语义完全不变,只做视觉升级:\n\n' + code)
    except Exception as e:
        if code is not None:
            print(f'\033[31mmermaid: AI 美化失败({e}),降级打开原稿\033[0m', file=sys.stderr)
            final = code
        else:
            err = str(e).replace('"', "'").replace('\n', ' ')[:80]
            write('flowchart LR\n'
                  f'    E["❌ AI 生成失败: {err}"]\n'
                  '    style E fill:#fee2e2,stroke:#dc2626,color:#7f1d1d\n')
            sys.exit(f'\033[31mmermaid: AI 生成失败: {e}\033[0m')

    write(sanitize(final))
    title = ''
    try:  # AI 起短名(存 serve.py 的 names.json,历史面板里显示);失败不影响出图
        req = urllib.request.Request(f'http://localhost:{PORT}/autoname',
                                     data=json.dumps({'f': name}).encode(),
                                     headers={'Content-Type': 'application/json'})
        with urllib.request.urlopen(req, timeout=30) as r:
            title = json.load(r).get('title', '')
    except Exception:
        pass
    print(f'mermaid: 完成 ✓' + (f' 「{title}」' if title else ''), file=sys.stderr)

if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print('\nmermaid: 已取消', file=sys.stderr)
        sys.exit(130)
